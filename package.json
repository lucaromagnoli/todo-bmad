{
  "name": "todo-bmad",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Single-user Todo app built using the BMAD-METHOD workflow.",
  "workspaces": [
    "apps/*",
    "e2e"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present --workspace=apps/api --workspace=apps/web",
    "test:coverage": "npm run test:coverage --workspaces --if-present --workspace=apps/api --workspace=apps/web",
    "test:e2e": "npm run test --workspace=e2e",
    "test:e2e:install": "npm run install:browsers --workspace=e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
